# ═══════════════════════════════════════════════════════════════
# AX Coding Agent 환경변수 (예시)
# cp .env.example .env 후 API 키를 입력하세요
# ═══════════════════════════════════════════════════════════════

# 글로벌 프로바이더 (dashscope | openrouter | anthropic)
LLM_PROVIDER=dashscope

# ── DashScope (Qwen 공식 API — 권장, OpenRouter Qwen3 timeout 회피) ──
# DASHSCOPE_BASE_URL은 반드시 개인 워크스페이스 전용 URL을 사용해야 합니다.
# 아래 예시의 dashscope-intl.aliyuncs.com 같은 글로벌 엔드포인트는
# 워크스페이스 ID 기반 라우팅이 되지 않아 모델 호출이 실패합니다.
#
# 워크스페이스 URL 확인 방법:
#   1. https://dashscope.console.aliyun.com/ 로그인
#   2. 좌측 메뉴 → "Workspace" → 본인 워크스페이스 선택
#   3. "Inference Endpoint" 또는 "API 호출 주소" 섹션에서 URL 복사
#      예: https://ws-<WORKSPACE_ID>.<REGION>.maas.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://ws-<YOUR_WORKSPACE_ID>.<REGION>.maas.aliyuncs.com/compatible-mode/v1

# ── z.ai (GLM 공식 API — 권장, 직접 호출) ──
# https://z.ai/manage-apikey/apikey-list 에서 API 키 발급
# 일반 엔드포인트: https://api.z.ai/api/paas/v4
# 코딩 전용 엔드포인트: https://api.z.ai/api/coding/paas/v4
ZAI_API_KEY=

# ── OpenRouter (대안 — GLM에는 안정적, Qwen3에는 불안정) ──
OPENROUTER_API_KEY=

# ── Anthropic (대안 — Claude 4.6) ──
ANTHROPIC_API_KEY=

# ═══════════════════════════════════════════════════════════════
# 4-Tier 모델 설정 — 4가지 구성 중 하나 선택
# ═══════════════════════════════════════════════════════════════

# [A] DashScope Qwen3 전체 (주력 — 6차 E2E 검증, 24.8분 66 파일)
REASONING_MODEL=dashscope/qwen3-max
STRONG_MODEL=dashscope/qwen3-coder-next
DEFAULT_MODEL=dashscope/qwen3.5-plus
FAST_MODEL=dashscope/qwen3.5-flash

# [B] z.ai GLM 직접 호출 (reasoning 모델 — 단일 호출 600초+ timeout 위험)
# REASONING_MODEL=z-ai/glm-5.1
# STRONG_MODEL=z-ai/glm-5.1-coding
# DEFAULT_MODEL=dashscope/qwen3-coder-next
# FAST_MODEL=dashscope/qwen3.5-flash

# [C] OpenRouter GLM-5 (5차 E2E 검증 — Qwen reviewer는 timeout 위험)
# REASONING_MODEL=openrouter/z-ai/glm-5
# STRONG_MODEL=openrouter/z-ai/glm-5
# DEFAULT_MODEL=openrouter/qwen/qwen3-coder-next
# FAST_MODEL=openrouter/qwen/qwen3.5-flash-02-23

# [D] Claude 4.6 (최고 품질 — LLM_TIMEOUT=600 필수, turn 제약 위험)
# REASONING_MODEL=claude-opus-4-6
# STRONG_MODEL=claude-sonnet-4-6
# DEFAULT_MODEL=claude-sonnet-4-6
# FAST_MODEL=claude-haiku-4-5

# ── Langfuse (관측성 — 선택) ──
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── LiteLLM Proxy ──
LITELLM_MASTER_KEY=sk-harness-local-dev
LITELLM_PROXY_URL=http://localhost:4001/v1

# ── 에이전트 설정 ──
MAX_ITERATIONS=50
LLM_TIMEOUT=600
MEMORY_DB_PATH=./memory_store/ax.v2.db
