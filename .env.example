# ═══════════════════════════════════════════════════════════════
# AX Coding Agent 환경변수 (예시)
# cp .env.example .env 후 API 키를 입력하세요
# ═══════════════════════════════════════════════════════════════

# 글로벌 프로바이더
LLM_PROVIDER=openrouter

# ── DashScope (Qwen 공식 API — 권장) ──
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── OpenRouter (대안) ──
OPENROUTER_API_KEY=

# ── Anthropic (Claude — 선택) ──
ANTHROPIC_API_KEY=

# ── 4-Tier 모델 설정 ──
# DashScope 직접 호출 (권장 — 안정적, 빠름)
REASONING_MODEL=dashscope/qwen3-max
STRONG_MODEL=dashscope/qwen3-coder-next
DEFAULT_MODEL=dashscope/qwen3.5-plus
FAST_MODEL=dashscope/qwen3.5-flash

# OpenRouter 경유 (대안)
# REASONING_MODEL=openrouter/qwen/qwen3-max
# STRONG_MODEL=openrouter/z-ai/glm-5
# DEFAULT_MODEL=openrouter/qwen/qwen3-coder-next
# FAST_MODEL=openrouter/qwen/qwen3.5-flash-02-23

# ── Langfuse (관측성 — 선택) ──
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── LiteLLM Proxy ──
LITELLM_MASTER_KEY=sk-harness-local-dev
LITELLM_PROXY_URL=http://localhost:4001/v1

# ── 에이전트 설정 ──
MAX_ITERATIONS=50
LLM_TIMEOUT=120
MEMORY_DB_PATH=./memory_store/memory.db
